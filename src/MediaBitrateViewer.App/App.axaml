<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MediaBitrateViewer.App.Converters"
             x:Class="MediaBitrateViewer.App.App"
             RequestedThemeVariant="Default">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://MediaBitrateViewer.App/Themes/Tokens.axaml" />
            </ResourceDictionary.MergedDictionaries>
            <conv:EnumDisplayConverter x:Key="EnumDisplay" />
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://MediaBitrateViewer.App/Styles/SharedStyles.axaml" />
    </Application.Styles>
</Application>
