<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Headings -->
    <Style Selector="TextBlock.h1">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.h2">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.h3">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- Body and labels -->
    <Style Selector="TextBlock.body">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="TextBlock.value">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.mono">
        <Setter Property="FontFamily" Value="Menlo, Consolas, 'JetBrains Mono', monospace" />
        <Setter Property="FontSize" Value="13" />
    </Style>
    <Style Selector="TextBlock.caption">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>

    <!-- Big readout -->
    <Style Selector="TextBlock.readout-value">
        <Setter Property="FontFamily" Value="Menlo, Consolas, 'JetBrains Mono', monospace" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <!-- Panels -->
    <Style Selector="Border.panel">
        <Setter Property="Background" Value="{DynamicResource Surface1Brush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Padding" Value="12" />
    </Style>
    <Style Selector="Border.toolbar">
        <Setter Property="Background" Value="{DynamicResource ChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,0,0,1" />
        <Setter Property="Padding" Value="12,8" />
    </Style>
    <Style Selector="Border.statusbar">
        <Setter Property="Background" Value="{DynamicResource ChromeBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="BorderThickness" Value="0,1,0,0" />
        <Setter Property="Padding" Value="12,4" />
    </Style>
    <Style Selector="Border.well">
        <Setter Property="Background" Value="{DynamicResource Surface2Brush}" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="Padding" Value="10,8" />
    </Style>

    <!-- Toolbar separator -->
    <Style Selector="Border.toolbar-separator">
        <Setter Property="Width" Value="1" />
        <Setter Property="Background" Value="{DynamicResource BorderSubtleBrush}" />
        <Setter Property="Margin" Value="6,4" />
    </Style>

    <!-- Stat block -->
    <Style Selector="StackPanel.stat">
        <Setter Property="Spacing" Value="2" />
    </Style>

    <!-- Drop overlay -->
    <Style Selector="Border.drop-overlay">
        <Setter Property="Background" Value="{DynamicResource AccentSoftBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
        <Setter Property="BorderThickness" Value="2" />
        <Setter Property="CornerRadius" Value="8" />
    </Style>
</Styles>
