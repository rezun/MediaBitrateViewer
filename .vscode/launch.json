{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Media Bitrate Viewer",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build app",
            "program": "${workspaceFolder}/src/MediaBitrateViewer.App/bin/Debug/net10.0/MediaBitrateViewer.App.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MediaBitrateViewer.App",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Run Media Bitrate Viewer (no build)",
            "type": "coreclr",
            "request": "launch",
            "program": "${workspaceFolder}/src/MediaBitrateViewer.App/bin/Debug/net10.0/MediaBitrateViewer.App.dll",
            "args": [],
            "cwd": "${workspaceFolder}/src/MediaBitrateViewer.App",
            "stopAtEntry": false,
            "console": "integratedTerminal",
            "env": {
                "DOTNET_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Attach to process",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}
